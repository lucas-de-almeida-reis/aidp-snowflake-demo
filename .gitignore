# Local Claude Code workspace
.claude/

# Notebook runtime config — copy config.sample.yaml to config.yaml and fill in
assets/aidp/config.yaml

# Private keys (OCI API keys, etc.) — NEVER commit
*.pem

# OAC config (OCIDs + fingerprint live here alongside the PEM — keep local-only)
assets/oac/

# Vendor drivers / archives — download from the vendor, don't commit binaries
*.jar
*.zip

# Tableau autosave / backup / lock files
*.twbr
.~*

# macOS
.DS_Store
